# SEO & Analytics Configuration
# Replace these with your actual IDs from Google Analytics & Tag Manager

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com
VITE_GA4_ID=G-XXXXXXXXXX

# Google Tag Manager Container ID
# Get from: https://tagmanager.google.com
VITE_GTM_ID=GTM-XXXXXXX

# Domain Configuration
VITE_SITE_URL=https://connectly.io

# Site Name
VITE_SITE_NAME=Connectly

# Business Email
VITE_SUPPORT_EMAIL=support@connectly.io

# Phone Number
VITE_PHONE_NUMBER=+1-XXXXXXXXX

# Social Media
VITE_LINKEDIN_URL=https://www.linkedin.com/company/connectly
VITE_TWITTER_URL=https://twitter.com/connectly
VITE_FACEBOOK_URL=https://www.facebook.com/connectly

# API Endpoints
VITE_API_BASE_URL=https://api.connectly.io
